# LLM
LLM_PROVIDER=gemini  # gemini | groq | anthropic
GEMINI_API_KEY=
GEMINI_MODEL_FAST=gemini-2.0-flash
GEMINI_MODEL_DEEP=gemini-2.0-pro-exp

# Groq (alternative free provider — Llama 3.3 70B)
GROQ_API_KEY=
GROQ_MODEL_FAST=llama-3.3-70b-versatile
GROQ_MODEL_DEEP=llama-3.3-70b-versatile

# Anthropic (заглушка на будущее)
ANTHROPIC_API_KEY=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Notion
NOTION_API_KEY=
NOTION_SYNC_ENABLED=true

# Misc
ENV=production
LOG_LEVEL=INFO
TZ=Europe/Vilnius
